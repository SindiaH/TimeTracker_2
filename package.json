{
  "name": "time-tracker-2",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "web:start": "ng serve",
    "build": "ng build",
    "web:build": "ng build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:dev": "ng build --configuration development",
    "build:test": "ng build --configuration test",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "prettier": "prettier --check \"src/**/*.{html,ts,scss,json,md}\"",
    "prettier:fix": "prettier --write \"src/**/*.{html,ts,scss,json,md}\"",
    "stylelint": "stylelint \"src/**/*.scss\"",
    "stylelint:fix": "stylelint --fix \"src/**/*.scss\"",
    "test": "ng test",
    "test:silent": "ng test --watch=false",
    "test:coverage": "ng test --watch=false --coverage",
    "prepare:pr": "npm run lint:fix && npm run prettier:fix && npm run stylelint:fix && npm run test:silent",
    "prepare": "husky"
  },
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@jsverse/transloco": "^8.3.0",
    "@supabase/supabase-js": "^2.105.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-store": "^2.4.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.3.1",
    "@angular-eslint/eslint-plugin": "21.3.1",
    "@angular-eslint/eslint-plugin-template": "21.3.1",
    "@angular-eslint/schematics": "21.3.1",
    "@angular-eslint/template-parser": "21.3.1",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@tauri-apps/cli": "^2.10.1",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "@typescript-eslint/utils": "8.58.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "16.4.0",
    "prettier": "^3.8.1",
    "stylelint": "17.8.0",
    "stylelint-config-standard-scss": "17.0.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "src/**/*.{ts,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.scss": [
      "stylelint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,md}": [
      "prettier --write"
    ]
  }
}
