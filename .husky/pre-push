# Make Node/pnpm visible to GUI Git clients (Fork, SourceTree, GitKraken, …)
# whose login PATH does not include Homebrew or nvm by default.
if [ -d "$HOME/.nvm" ]; then
  export NVM_DIR="$HOME/.nvm"
  # shellcheck disable=SC1091
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh" --no-use
  # shellcheck disable=SC1091
  [ -s "$NVM_DIR/nvm.sh" ] && nvm use --silent default >/dev/null 2>&1 || true
fi

for candidate in /opt/homebrew/bin /usr/local/bin "$HOME/.volta/bin" "$HOME/.fnm" "$HOME/.bun/bin" "$HOME/Library/pnpm" "$HOME/.local/share/pnpm"; do
  [ -d "$candidate" ] && case ":$PATH:" in
    *":$candidate:"*) ;;
    *) PATH="$candidate:$PATH" ;;
  esac
done
export PATH

if ! command -v pnpm >/dev/null 2>&1; then
  echo "husky pre-push: 'pnpm' not found in PATH=$PATH" >&2
  echo "  → install pnpm (https://pnpm.io/installation) or expose your existing pnpm install to GUI Git clients." >&2
  exit 1
fi

pnpm run test:silent
