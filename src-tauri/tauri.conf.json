{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TimeTrack2",
  "version": "0.1.0",
  "identifier": "com.electron.timetrack2",
  "build": {
    "frontendDist": "../dist/TimeTracker_2/browser",
    "devUrl": "http://localhost:54321",
    "beforeDevCommand": "npm start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TimeTrack2",
        "width": 1280,
        "height": 800,
        "minWidth": 480,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.mac.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["timesapp2"]
      }
    }
  }
}
